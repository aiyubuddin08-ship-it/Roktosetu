rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "aiyubuddin08@gmail.com" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // ===============================================================
    // Validation Blueprints
    // ===============================================================
    
    function isValidUser(data) {
      return data.uid is string && 
             data.uid.size() <= 128 &&
             data.displayName is string &&
             data.displayName.size() <= 100 &&
             data.email is string &&
             data.bloodGroup is string &&
             (data.role == 'user' || data.role == 'admin');
    }

    function isValidRequest(data) {
      return data.requesterId is string && 
             data.requesterId.size() <= 128 &&
             data.bloodGroup is string &&
             data.status is string &&
             data.hospitalName is string &&
             data.hospitalName.size() <= 200;
    }

    function isValidOrganization(data) {
      return data.name is string &&
             data.name.size() <= 200 &&
             data.adminUid is string &&
             data.adminUid.size() <= 128 &&
             data.type is string;
    }

    function isValidDonation(data) {
      return data.userId is string &&
             data.userId.size() <= 128 &&
             data.date is string &&
             data.bloodGroup is string &&
             data.pointsEarned is number;
    }

    function isValidHealthRecord(data) {
      return data.userId is string &&
             data.userId.size() <= 128 &&
             data.date is string &&
             data.bloodPressure is string &&
             data.bloodPressure.size() <= 20 &&
             data.hemoglobin is number &&
             data.weight is number;
    }

    function isValidCertificate(data) {
      return data.userId is string &&
             data.userId.size() <= 128 &&
             data.donorName is string &&
             data.donorName.size() <= 100 &&
             data.donationDate is string &&
             data.certificateNo is string;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() || (resource != null && resource.data.isDonor == true);
      
      allow create: if isOwner(userId) && 
                      isValidUser(incoming()) && 
                      (incoming().role == 'user' || isAdmin()) &&
                      incoming().uid == request.auth.uid;
      
      allow update: if (isOwner(userId) && (
        (incoming().role == existing().role || isAdmin()) &&
        incoming().uid == existing().uid &&
        isValidUser(incoming())
      )) || isAdmin() || (
        // Allow stats to be updated by the system/recipient during 'Mark as Donated'
        isAuthenticated() && incoming().diff(existing()).affectedKeys()
        .hasOnly(['donationsCount', 'points', 'ratingCount', 'ratingAverage', 'lastDonated', 'organizationId', 'organizationName', 'badges'])
      );
      
      allow delete: if isAdmin();

      match /donations/{donationId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isAuthenticated() && isValidDonation(incoming());
        allow update, delete: if isOwner(userId) || isAdmin();
      }
    }

    match /organizations/{orgId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidOrganization(incoming()) && incoming().adminUid == request.auth.uid;
      allow update: if (isAuthenticated() && (existing().adminUid == request.auth.uid || isAdmin())) || 
                    (isAuthenticated() && incoming().diff(existing()).affectedKeys().hasOnly(['memberCount']));
      allow delete: if isAdmin() || (isAuthenticated() && existing().adminUid == request.auth.uid);
    }

    match /requests/{requestId} {
      allow read: if true;
      
      allow create: if isAuthenticated() && 
                      isValidRequest(incoming()) &&
                      (incoming().requesterId == request.auth.uid || isAdmin());
                    
      allow update: if isAuthenticated() && (
        isAdmin() || 
        (request.auth.uid == existing().requesterId) ||
        // Allow marking as completed or updating status by a relevant process
        incoming().diff(existing()).affectedKeys().hasOnly(['status', 'completedAt', 'donorId', 'rating'])
      );
      
      allow delete: if isAdmin() || (isAuthenticated() && request.auth.uid == existing().requesterId);
    }

    match /directory/{entryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /resources/{resourceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /health_tips/{tipId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /stories/{storyId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (request.auth.uid == existing().authorId || isAdmin() || 
                    incoming().diff(existing()).affectedKeys().hasOnly(['likes']));
      allow delete: if isAuthenticated() && (request.auth.uid == existing().authorId || isAdmin());
    }

    match /events/{eventId} {
      allow read: if true; // Publicly readable
      allow write: if isAdmin() || (isAuthenticated() && (
        (incoming() != null && get(/databases/$(database)/documents/organizations/$(incoming().orgId)).data.adminUid == request.auth.uid) ||
        (existing() != null && get(/databases/$(database)/documents/organizations/$(existing().orgId)).data.adminUid == request.auth.uid)
      ));
    }

    match /alerts/{alertId} {
      allow read: if true;
      allow write: if isAdmin() || (isAuthenticated() && (
        (incoming() != null && get(/databases/$(database)/documents/organizations/$(incoming().orgId)).data.adminUid == request.auth.uid) ||
        (existing() != null && get(/databases/$(database)/documents/organizations/$(existing().orgId)).data.adminUid == request.auth.uid)
      ));
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (request.auth.uid == existing().userId || isAdmin());
      allow create: if isAuthenticated() && incoming().userId is string;
      allow update: if isAuthenticated() && (request.auth.uid == existing().userId || isAdmin());
      allow delete: if isAuthenticated() && (request.auth.uid == existing().userId || isAdmin());
    }

    match /chats/{chatId} {
      allow read, update: if isAuthenticated() && request.auth.uid in existing().participants;
      allow create: if isAuthenticated() && request.auth.uid in incoming().participants;

      match /messages/{messageId} {
        allow read: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isAuthenticated() && 
                      request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants &&
                      incoming().senderId == request.auth.uid;
      }
    }

    match /health_records/{recordId} {
      allow list: if isAuthenticated() && (resource.data.userId == request.auth.uid || request.auth.token.email == "aiyubuddin08@gmail.com");
      allow get: if isAuthenticated() && (resource.data.userId == existing().userId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == incoming().userId && isValidHealthRecord(incoming());
      allow update, delete: if isAuthenticated() && (request.auth.uid == existing().userId || isAdmin());
    }

    match /certificates/{certId} {
      allow list: if isAuthenticated() && (resource.data.userId == request.auth.uid || request.auth.token.email == "aiyubuddin08@gmail.com");
      allow get: if isAuthenticated() && (resource.data.userId == existing().userId || isAdmin());
      allow create: if isAdmin() && isValidCertificate(incoming());
      allow update, delete: if isAdmin();
    }

    match /campaign_participants/{participantId} {
      allow list: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || 
        isAdmin() ||
        resource.data.orgAdminUid == request.auth.uid ||
        (resource.data.orgId != null && get(/databases/$(database)/documents/organizations/$(resource.data.orgId)).data.adminUid == request.auth.uid)
      );
      allow get: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || 
        isAdmin() ||
        resource.data.orgAdminUid == request.auth.uid ||
        (resource.data.orgId != null && get(/databases/$(database)/documents/organizations/$(resource.data.orgId)).data.adminUid == request.auth.uid)
      );
      allow create: if isAuthenticated() && incoming().userId == request.auth.uid;
      allow update, delete: if isAdmin() || (isAuthenticated() && (existing().userId == request.auth.uid || existing().orgAdminUid == request.auth.uid || (existing().orgId != null && get(/databases/$(database)/documents/organizations/$(existing().orgId)).data.adminUid == request.auth.uid)));
    }
  }
}
